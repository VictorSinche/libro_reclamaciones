APP_NAME="Libro Reclamaciones"
APP_ENV=local
APP_KEY=base64:hjxi6x34AO1xIQftnBnAWX8Pse6NhWakKu2n7B7fkqg=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

# CONEXIÓN A BASE DE DATOS (Docker Compose)
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=lib_reclamaciones
DB_USERNAME=laraveluser
DB_PASSWORD=laravelpass

# EMAIL (Office365)
MAIL_MAILER=smtp
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=notificaciones@uma.edu.pe
MAIL_PASSWORD=Mirell@x100pre
MAIL_ENCRYPTION=STARTTLS
MAIL_FROM_ADDRESS=notificaciones@uma.edu.pe
MAIL_FROM_NAME="Libro de reclamaciones"
MAIL_RESPONSABLE_RECLAMO=

# SESIONES Y COLAS
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=database
CACHE_STORE=database

# REDIS (opcional)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# AWS (no usado, pero configurado por defecto)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
